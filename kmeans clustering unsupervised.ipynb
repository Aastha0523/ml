   "source": [
    "from sklearn.datasets import load_iris\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "# Load data\n",
    "X, _ = load_iris(return_X_y=True)\n",
    "\n",
    "# Train KMeans\n",
    "model = KMeans(n_clusters=3, random_state=42)\n",
    "model.fit(X)\n",
    "\n",
    "# Cluster labels\n",
    "print(\"Clusters:\", model.labels_[:10])"
   ]
